// Example using promise and future
// to send a result from a producer thread
// to a consumer thread
#include <future>
#include <iostream>
#include <thread>
#include <chrono>

using namespace std;
using namespace std::literals;

// The producer's task function takes a promise as argument
void produce(promise<int>& px)
{
	// Produce the result
    int x = 42;
    this_thread::sleep_for(2s);
	
	// Store the result in the shared state
	cout << "Promise sets shared state to " << x << '\n';
    px.set_value(x);
}

// The consumer's task function takes a future as argument
void consume(future<int>& fx)
{
	// Get the result from the shared state
	cout << "Future calling get()...\n";
    int x = fx.get();
    cout << "Future returns from calling get()\n";
	cout << "The answer is " << x << '\n';
}

int main()
{
	// Create a promise object
	// This creates an associated future object
	// and sets up a shared state between them
    promise<int> prom;
	
	// Get the future associated with the promise
    future<int> fut = prom.get_future();
    
	// Start the threads
	// The producer task function takes the promise as argument
    thread thr_producer(produce, ref(prom));
	
	// The consumer task function takes the future as argument
    thread thr_consumer(consume, ref(fut));
    
    thr_consumer.join();
    thr_producer.join();
}
