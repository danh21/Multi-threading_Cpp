#!/bin/bash

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only trigger for normal commits (not merge/amend)
if [ -n "$COMMIT_SOURCE" ]; then
    exit 0
fi

# Get staged files and folders
staged_files=$(git diff --cached --name-only)

if [ -z "$staged_files" ]; then
    exit 0
fi

# Build suggestion block
suggestion="# ── Last commits per staged file/folder ─────────\n"

while IFS= read -r file; do
    # Last commit of this specific file
    last_commit=$(git log --oneline -1 -- "$file" 2>/dev/null)

    if [ -n "$last_commit" ]; then
        suggestion+="# 📄 $file\n"
        suggestion+="#    └─ $last_commit\n"
    else
        suggestion+="# 📄 $file\n"
        suggestion+="#    └─ (no previous commit)\n"
    fi
done <<< "$staged_files"

suggestion+="# ─────────────────────────────────────────────\n"

# Prepend suggestion to commit message file
current=$(cat "$COMMIT_MSG_FILE")
printf "%b\n%s" "$suggestion" "$current" > "$COMMIT_MSG_FILE"